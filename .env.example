# ==============================================
# gmaps-scraper — Environment Variables
# ==============================================
# These are documentation-only defaults.
# The app reads CLI arguments, not env vars (unless you add that feature).

# Override default headless mode for the browser
# OPTIONAL — defaults to false (headed mode) when run via CLI
SCRAPER_HEADLESS=true

# Default collection limit if --limit is not passed
# OPTIONAL — CLI default is 200
SCRAPER_DEFAULT_LIMIT=200

# Directory where JSON output files are saved
# OPTIONAL — CLI default is ./results.json
SCRAPER_OUTPUT_DIR=./results

# Logging verbosity level: DEBUG, INFO, WARNING
# OPTIONAL — defaults to INFO
LOG_LEVEL=INFO

# Custom browser cache path inside Docker container
# OPTIONAL — Playwright auto-detects this
PLAYWRIGHT_BROWSERS_PATH=/app/.playwright
